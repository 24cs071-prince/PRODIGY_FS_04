# Dependencies (do not upload node_modules, they can be re-installed using npm install)
node_modules/
**/node_modules/

# Production builds
dist/
**/dist/
build/
**/build/

# Local configuration / secrets
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# Database files
*.db
*.sqlite
chat.db

# Log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Compressed archives (like node_modules.zip or server.zip)
*.zip
*.tar.gz
*.tgz
*.rar

# Uploads directory contents (keeps the folder but ignores user-uploaded files)
server/uploads/*
!server/uploads/.gitkeep

# IDE and OS files
.vscode/
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
